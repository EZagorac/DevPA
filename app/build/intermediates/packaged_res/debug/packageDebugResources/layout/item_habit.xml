<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:animateLayoutChanges="true"
    android:background="@drawable/card_background"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Zone 1 — Check-in row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/check_habit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:buttonTint="@color/accent_green" />

        <TextView
            android:id="@+id/tv_habit_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btn_overflow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="⋮"
            android:textSize="20sp"
            android:textColor="@color/text_muted"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Zone 1.5 — Streak at risk warning -->
    <TextView
        android:id="@+id/tv_streak_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="#FFC04A"
        android:textColor="#0E0F11"
        android:padding="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:text="⚠ Streak at risk — not done yet today" />

    <!-- Zone 2 — Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_green"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STREAK"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp"
                    android:letterSpacing="0.06" />

            </LinearLayout>

            <!-- Days tracked -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_days_tracked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_amber"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAYS TRACKED"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp"
                    android:letterSpacing="0.06" />

            </LinearLayout>

            <!-- Best streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_best_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_teal"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp"
                    android:letterSpacing="0.06" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_completion_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Zone 3 — Dot history row (populated programmatically) -->
    <LinearLayout
        android:id="@+id/dot_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="44dp" />

</LinearLayout>
