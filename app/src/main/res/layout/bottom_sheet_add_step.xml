<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New step"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <AutoCompleteTextView
            android:id="@+id/et_step_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What needs to be done?"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:inputType="textCapSentences"
            android:layout_marginBottom="12dp" />

        <AutoCompleteTextView
            android:id="@+id/et_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Group (optional)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:inputType="textCapWords"
            android:completionThreshold="1"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/et_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description (optional)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2"
            android:layout_marginBottom="12dp" />

        <!-- Due date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due date (optional)"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_set_date"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set date"
                android:textColor="@color/accent_teal" />

            <TextView
                android:id="@+id/tv_selected_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:visibility="gone"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/btn_clear_date"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/text_muted"
                android:visibility="gone" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_add_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add step"
            android:enabled="false"
            app:backgroundTint="@color/accent_green"
            android:textColor="#0E0F11" />

    </LinearLayout>

</ScrollView>
