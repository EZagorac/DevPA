<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_step_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_category_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:background="@color/bg_surface2"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Progress seekbar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progress"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seek_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="@color/accent_teal"
            android:thumbTint="@color/accent_teal" />

        <TextView
            android:id="@+id/tv_progress_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/accent_teal"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Notes -->
        <EditText
            android:id="@+id/et_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Add notes..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="12dp" />

        <!-- Due date -->
        <TextView
            android:id="@+id/tv_due_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Toggle done -->
        <Button
            android:id="@+id/btn_toggle_done"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mark complete"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@color/accent_green"
            android:textColor="#0E0F11" />

        <!-- Delete -->
        <Button
            android:id="@+id/btn_delete_step"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete step"
            android:textColor="@color/accent_red" />

    </LinearLayout>

</ScrollView>
