<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_journey_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F0F0EE"
        android:textSize="13sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <ProgressBar
        android:id="@+id/widget_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#7FFF6E"
        android:layout_marginBottom="3dp" />

    <TextView
        android:id="@+id/widget_progress_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888A8F"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <!-- Step row 0 -->
    <LinearLayout
        android:id="@+id/widget_step_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/widget_step_check_0"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text=""
            android:padding="0dp"
            android:background="#2A3A2A"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_step_label_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#F0F0EE"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_step_pct_0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4FD1C5"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Step row 1 -->
    <LinearLayout
        android:id="@+id/widget_step_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/widget_step_check_1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text=""
            android:padding="0dp"
            android:background="#2A3A2A"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_step_label_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#F0F0EE"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_step_pct_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4FD1C5"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Step row 2 -->
    <LinearLayout
        android:id="@+id/widget_step_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/widget_step_check_2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text=""
            android:padding="0dp"
            android:background="#2A3A2A"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_step_label_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#F0F0EE"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_step_pct_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4FD1C5"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>
