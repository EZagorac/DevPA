<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PORTFOLIO CHECKLIST"
        android:textColor="@color/accent_green"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your path from zero to hired"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Progress"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_portfolio"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progressTint="@color/accent_green"
        android:progressBackgroundTint="@color/border"
        android:layout_marginBottom="16dp"
        android:max="100" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_portfolio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
