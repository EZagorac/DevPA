<?xml version="1.0" encoding="utf-8"?>
<!-- Small widget: ~2x1 cells. All views must be RemoteViews-compatible types. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_habit_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F0F0EE"
        android:textSize="11sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="2dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7FFF6E"
            android:textSize="28sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/widget_today_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_streak_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888A8F"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
